{
  "name": "@clily/core",
  "version": "0.1.0",
  "description": "A modern, ergonomic TypeScript CLI framework with Standard Schema validation",
  "homepage": "https://github.com/jkker/clily#readme",
  "bugs": {
    "url": "https://github.com/jkker/clily/issues"
  },
  "license": "MIT",
  "author": "jkker <j@erry.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkker/clily.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@standard-schema/spec": "^1.1.0",
    "c12": "4.0.0-beta.4",
    "consola": "catalog:",
    "defu": "catalog:"
  },
  "devDependencies": {
    "@types/json-schema": "catalog:",
    "arktype": "^2.2.0",
    "zod": "^4.3.6"
  }
}

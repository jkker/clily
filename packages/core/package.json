{
  "name": "@clily/core",
  "version": "0.1.0",
  "description": "A modern, ergonomic TypeScript CLI framework with Standard Schema validation",
  "homepage": "https://github.com/Jkker/clily#readme",
  "bugs": {
    "url": "https://github.com/Jkker/clily/issues"
  },
  "license": "MIT",
  "author": "Jkker <j@erry.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jkker/clily.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp run build && vp test --typecheck",
    "check": "rm -rf dist && vp check",
    "validate:dist": "vp run build && vp test --run tests/package-surface.test.ts",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@standard-schema/spec": "^1.1.0",
    "c12": "4.0.0-beta.4",
    "citty": "^0.2.1",
    "consola": "^3.4.2",
    "defu": "^6.1.4",
    "omelette": "^0.4.17",
    "std-env": "^4.0.0"
  },
  "devDependencies": {
    "arktype": "^2.2.0",
    "bumpp": "^11.0.1",
    "valibot": "^1.3.1",
    "zod": "^4.3.6"
  }
}

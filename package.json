{
  "name": "clily",
  "version": "0.0.0",
  "description": "A modern, ergonomic TypeScript CLI framework with Standard Schema validation",
  "homepage": "https://github.com/Jkker/clily#readme",
  "bugs": {
    "url": "https://github.com/Jkker/clily/issues"
  },
  "license": "MIT",
  "author": "Author Name <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jkker/clily.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@standard-schema/spec": "^1.1.0",
    "c12": "4.0.0-beta.4",
    "citty": "^0.2.1",
    "consola": "^3.4.2",
    "defu": "^6.1.4",
    "omelette": "^0.4.17",
    "picocolors": "^1.1.1",
    "std-env": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "@vitest/coverage-v8": "^4.1.1",
    "arktype": "^2.2.0",
    "bumpp": "^11.0.1",
    "typescript": "^5.9.3",
    "valibot": "^1.3.1",
    "vite-plus": "^0.1.11",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
